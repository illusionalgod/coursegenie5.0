.input-area {/* Main Content Area */.welcome-message {

  padding: 16px 20px;

  background-color: var(--bg-primary);.main-content {  background-color: var(--bg-tertiary) !important;

  border-top: 1px solid var(--border-color);

}  margin-left: var(--sidebar-width);  border-left: 4px solid var(--accent);



.input-container {  height: 100vh;}

  max-width: 800px;

  margin: 0 auto;  display: flex;

  display: flex;

  gap: 12px;  flex-direction: column;.example-questions {

  align-items: center;

}  transition: margin-left 0.3s ease;  display: flex;



#chat-form {}  flex-wrap: wrap;

  display: flex;

  gap: 12px;  gap: 8px;

  align-items: center;

  width: 100%;.sidebar.collapsed ~ .main-content {  margin-top: 12px;

}

  margin-left: 0;}

#chat-input {

  flex: 1;}

  padding: 14px 16px;

  background-color: var(--bg-secondary);.example-btn {

  border: 1px solid var(--border-color);

  border-radius: 12px;.top-header {  background-color: var(--accent);

  color: var(--text-primary);

  font-size: 15px;  display: flex;  color: white;

  font-family: inherit;

  outline: none;  align-items: center;  border: none;

  transition: all 0.2s;

}  justify-content: space-between;  padding: 8px 12px;



#chat-input:focus {  padding: 16px 20px;  border-radius: 16px;

  border-color: var(--accent);

  background-color: var(--bg-tertiary);  border-bottom: 1px solid var(--border-color);  cursor: pointer;

}

  background-color: var(--bg-primary);  font-size: 13px;

#chat-input::placeholder {

  color: var(--text-secondary);  min-height: 60px;  transition: all 0.2s ease;

}

}}

.send-btn {

  padding: 14px 24px;

  background-color: var(--accent);

  color: white;.header-title {.example-btn:hover {

  border: none;

  border-radius: 12px;  font-size: 16px;  background-color: var(--accent-hover);

  font-size: 15px;

  font-weight: 500;  font-weight: 600;  transform: translateY(-2px);

  cursor: pointer;

  transition: background-color 0.2s;  color: var(--text-primary);  box-shadow: 0 2px 8px rgba(65, 105, 225, 0.3);

}

  flex: 1;}

.send-btn:hover:not(:disabled) {

  background-color: var(--accent-hover);  text-align: center;

}

}/* Typing indicator animation */

.send-btn:disabled {

  opacity: 0.5;.typing-indicator .typing-dots {

  cursor: not-allowed;

}.header-actions {  display: inline-block;



/* Scrollbar Styling */  display: flex;}

.chat-area::-webkit-scrollbar,

.chat-history::-webkit-scrollbar {  gap: 8px;

  width: 6px;

}}.typing-indicator .typing-dots span {



.chat-area::-webkit-scrollbar-track,  animation: typing 1.4s infinite;

.chat-history::-webkit-scrollbar-track {

  background: transparent;.icon-btn {  opacity: 0;

}

  background: none;}

.chat-area::-webkit-scrollbar-thumb,

.chat-history::-webkit-scrollbar-thumb {  border: none;

  background: var(--border-color);

  border-radius: 3px;  color: var(--text-secondary);.typing-indicator .typing-dots span:nth-child(1) {

}

  cursor: pointer;  animation-delay: 0s;

.chat-area::-webkit-scrollbar-thumb:hover,

.chat-history::-webkit-scrollbar-thumb:hover {  padding: 8px;}

  background: var(--text-secondary);

}  border-radius: 8px;



/* Responsive Design */  display: flex;.typing-indicator .typing-dots span:nth-child(2) {

@media (max-width: 768px) {

  .sidebar {  align-items: center;  animation-delay: 0.2s;

    transform: translateX(-100%);

  }  justify-content: center;}

  

  .sidebar.open {  transition: all 0.2s ease;

    transform: translateX(0);

  }}.typing-indicator .typing-dots span:nth-child(3) {

  

  .main-content {  animation-delay: 0.4s;

    margin-left: 0;

  }.icon-btn:hover {}

  

  .mobile-toggle {  background-color: var(--bg-hover);

    display: flex;

  }  color: var(--text-primary);@keyframes typing {

  

  .example-prompts {}  0%,

    grid-template-columns: 1fr;

  }  60%,

  

  .welcome-title {/* Chat Area */  100% {

    font-size: 24px;

  }.chat-area {    opacity: 0;

}

  flex: 1;  }

@media (max-width: 480px) {

  .chat-area {  overflow-y: auto;  30% {

    padding: 12px;

  }  padding: 20px;    opacity: 1;

  

  .input-area {  display: flex;  }

    padding: 12px;

  }  flex-direction: column;}

  

  .send-btn {  background-color: var(--bg-primary);

    padding: 14px 16px;

  }}/* User and bot message styling */

}

.user-message {

.chat-area::-webkit-scrollbar {  background-color: var(--bg-user-msg) !important;

  width: 6px;  margin-left: 10%;

}  border-radius: 8px;

  color: white !important;

.chat-area::-webkit-scrollbar-track {}

  background: transparent;

}.bot-message {

  background-color: var(--bg-secondary) !important;

.chat-area::-webkit-scrollbar-thumb {  margin-right: 10%;

  background-color: var(--border-color);  border-radius: 8px;

  border-radius: 3px;}

}

.error-message {

/* Welcome Screen */  background-color: var(--error-bg) !important;

.welcome-screen {  border-left: 4px solid var(--error-border);

  display: flex;}

  flex-direction: column;

  align-items: center;/* Header buttons */

  justify-content: center;.header-buttons {

  height: 100%;  display: flex;

  max-width: 800px;  gap: 10px;

  margin: 0 auto;  margin-left: auto;

  text-align: center;}

  padding: 40px 20px;

}.header-btn {

  background-color: var(--bg-secondary);

.welcome-icon {  color: var(--text-primary);

  width: 64px;  border: 1px solid var(--bg-tertiary);

  height: 64px;  padding: 8px 12px;

  margin-bottom: 24px;  border-radius: 5px;

  border-radius: 16px;  cursor: pointer;

}  font-size: 14px;

  transition: all 0.2s ease;

.welcome-title {}

  font-size: 28px;

  font-weight: 600;.header-btn:hover {

  margin-bottom: 32px;  background-color: var(--input-hover);

  color: var(--text-primary);}

}

.header-btn.clear-btn:hover {

.example-prompts {  background-color: var(--error-bg);

  display: grid;  color: white;

  grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));}

  gap: 12px;
  width: 100%;
  max-width: 700px;
}

.prompt-card {
  background-color: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: 12px;
  padding: 16px 20px;
  text-align: left;
  cursor: pointer;
  transition: all 0.2s ease;
  font-size: 14px;
  color: var(--text-primary);
}

.prompt-card:hover {
  background-color: var(--bg-hover);
  border-color: var(--accent);
}

.prompt-icon {
  font-size: 20px;
  margin-bottom: 8px;
}

/* Messages */
.message {
  padding: 20px 0;
  animation: fadeIn 0.3s ease;
}

@keyframes fadeIn {
  from {
    opacity: 0;
    transform: translateY(10px);
  }
  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.message-content {
  max-width: 800px;
  margin: 0 auto;
}

.message-role {
  font-size: 13px;
  font-weight: 600;
  margin-bottom: 8px;
  color: var(--text-secondary);
  text-transform: uppercase;
  letter-spacing: 0.5px;
}

.message-text {
  font-size: 15px;
  line-height: 1.6;
  color: var(--text-primary);
}

.user-message .message-role {
  color: var(--accent);
}

.bot-message .message-text {
  color: var(--text-primary);
}

.typing-indicator {
  display: flex;
  gap: 4px;
  align-items: center;
  padding: 20px 0;
}

.typing-indicator .message-content {
  display: flex;
  gap: 4px;
}

.typing-dot {
  width: 8px;
  height: 8px;
  background-color: var(--text-tertiary);
  border-radius: 50%;
  animation: typing 1.4s infinite;
}

.typing-dot:nth-child(2) {
  animation-delay: 0.2s;
}

.typing-dot:nth-child(3) {
  animation-delay: 0.4s;
}

@keyframes typing {
  0%, 60%, 100% {
    opacity: 0.3;
    transform: scale(0.8);
  }
  30% {
    opacity: 1;
    transform: scale(1);
  }
}

/* Input Area */
.input-area {
  padding: 20px;
  background-color: var(--bg-primary);
  border-top: 1px solid var(--border-color);
}

#chat-form {
  max-width: 800px;
  margin: 0 auto;
}

.input-wrapper {
  position: relative;
  display: flex;
  align-items: center;
  background-color: var(--bg-secondary);
  border: 1px solid var(--border-color);
  border-radius: 12px;
  padding: 12px 16px;
  transition: all 0.2s ease;
}

.input-wrapper:focus-within {
  border-color: var(--accent);
  background-color: var(--bg-primary);
}

#chat-input {
  flex: 1;
  background: none;
  border: none;
  outline: none;
  font-size: 15px;
  color: var(--text-primary);
  font-family: inherit;
}

#chat-input::placeholder {
  color: var(--text-tertiary);
}

.send-btn {
  background-color: var(--accent);
  border: none;
  border-radius: 8px;
  color: white;
  cursor: pointer;
  padding: 8px;
  display: flex;
  align-items: center;
  justify-content: center;
  transition: all 0.2s ease;
  margin-left: 8px;
}

.send-btn:hover {
  background-color: var(--accent-hover);
}

.send-btn:disabled {
  opacity: 0.5;
  cursor: not-allowed;
}

.input-footer {
  text-align: center;
  font-size: 12px;
  color: var(--text-tertiary);
  margin-top: 12px;
}

/* Responsive Design */
@media (max-width: 768px) {
  :root {
    --sidebar-width: 280px;
  }

  .sidebar {
    transform: translateX(-100%);
  }

  .sidebar.open {
    transform: translateX(0);
  }

  .sidebar.collapsed {
    transform: translateX(-100%);
  }

  .main-content {
    margin-left: 0;
  }

  .mobile-toggle {
    display: flex;
  }

  .welcome-title {
    font-size: 24px;
  }

  .example-prompts {
    grid-template-columns: 1fr;
  }

  .top-header {
    padding: 12px 16px;
  }

  .chat-area {
    padding: 16px;
  }

  .input-area {
    padding: 16px;
  }
}

@media (max-width: 480px) {
  .header-title {
    font-size: 14px;
  }

  .welcome-title {
    font-size: 20px;
  }

  .message-content {
    padding: 0 8px;
  }
}
